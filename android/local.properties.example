# Copy to android/local.properties (do not commit secrets)

sdk.dir=C\:\\Users\\YourName\\AppData\\Local\\Android\\Sdk

# Optional Supabase (leave empty if unused)
supabase.url=
supabase.anon.key=

# Release signing (optional — release build falls back to debug signing when unset)
# release.keystore.file=C\:\\path\\to\\visioai-release.jks
# release.keystore.password=
# release.key.alias=
# release.key.password=
